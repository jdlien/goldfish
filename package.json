{
  "name": "goldfish",
  "version": "0.1.0",
  "description": "AI agent runtime — a Claude Code-native Slack bot with persistent memory",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "bin": {
    "goldfish": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "@slack/bolt": "^4.1.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^13.0.0",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "kysely": "^0.28.9",
    "patchright": "^1.59.1",
    "pino": "^10.1.0",
    "proper-lockfile": "^4.1.2",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
