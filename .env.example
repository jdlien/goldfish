# Slack tokens (required)
SLACK_APP_TOKEN=xapp-1-...
SLACK_BOT_TOKEN=xoxb-...

# Goldfish configuration
GOLDFISH_WORKSPACE=/path/to/your/agent-workspace
GOLDFISH_DM_CHANNEL_ID=
GOLDFISH_CHANNELS=
GOLDFISH_MAX_TURNS=50
GOLDFISH_TIMEOUT_MS=900000
GOLDFISH_SESSION_EXPIRY_MS=86400000
GOLDFISH_SHOW_THINKING=true

# Claude thinking effort: low | medium | high | xhigh | max.
# Lower = faster/shallower, higher = slower/more deliberate. Leave unset for the CLI default.
GOLDFISH_EFFORT=
# Per-channel overrides as a JSON map of channelId -> level. Beats GOLDFISH_EFFORT.
# IMPORTANT: wrap the value in SINGLE quotes — .env is sourced by bash (launchd/goldfish-env.sh),
# which strips double quotes and would corrupt the JSON into an empty map.
# GOLDFISH_EFFORT_BY_CHANNEL='{"C0CASUAL123":"low","C0WORK456":"high"}'
