# Slack tokens (required)
SLACK_APP_TOKEN=xapp-1-...
SLACK_BOT_TOKEN=xoxb-...

# Goldfish configuration
GOLDFISH_WORKSPACE=/path/to/your/agent-workspace
GOLDFISH_DM_CHANNEL_ID=
GOLDFISH_CHANNELS=
GOLDFISH_MAX_TURNS=50
GOLDFISH_TIMEOUT_MS=900000
GOLDFISH_SESSION_EXPIRY_MS=86400000
GOLDFISH_SHOW_THINKING=true
